# Agent Prometheus environment example
# Copy this file to .env and fill in real secrets locally.
# Never commit .env.

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
PROMETHEUS_WORKSPACE=workspace
PROMETHEUS_AUTO_APPLY=false
PROMETHEUS_MAX_FILES=120
PROMETHEUS_MAX_FILE_CHARS=6000
PROMETHEUS_EVIDENCE_BUDGET=28000
PROMETHEUS_TASK_QUEUE=prometheus_tasks
PROMETHEUS_LOG_STREAM=prometheus_logs
PROMETHEUS_NOTIFICATION_CHANNEL=prometheus_notifications
PROMETHEUS_KILL_SWITCH_KEY=prometheus_kill_switch

# -----------------------------------------------------------------------------
# Redis
# Docker Compose uses host "redis" inside containers.
# Local host runs may use 127.0.0.1.
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Model routing
# Prometheus talks to an OpenAI-compatible endpoint.
# In Docker Compose, this points at LiteLLM.
# -----------------------------------------------------------------------------
OPENAI_API_BASE=http://litellm:4000/v1
OPENAI_API_KEY=sk-prometheus-dummy
PROMETHEUS_CONSULTANT_MODEL=consultant-model
PROMETHEUS_CHEAP_MODEL=utility-model

# -----------------------------------------------------------------------------
# Provider keys used by LiteLLM
# Keep real keys only in your local .env or server secret manager.
# -----------------------------------------------------------------------------
REAL_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Telegram integration
# TELEGRAM_CHAT_ID is also used as the authorized owner ID by telegram_gateway.py.
# -----------------------------------------------------------------------------
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Service ports
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
DASHBOARD_PORT=5173
LITELLM_PORT=4000
CHROMA_PORT=8001
