# Runtime environment example
# Copy this file to .env and fill in real secrets locally.
# Never commit .env.

# -----------------------------------------------------------------------------
# Product/runtime naming
# Change this value to rename the system without editing code.
# -----------------------------------------------------------------------------
APP_NAME=Workspace Runtime

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
PROMETHEUS_WORKSPACE=workspace
PROMETHEUS_AUTO_APPLY=false
PROMETHEUS_REQUIRE_APPROVAL=true
PROMETHEUS_MAX_FILES=80
PROMETHEUS_MAX_FILE_CHARS=4000
PROMETHEUS_EVIDENCE_BUDGET=18000
PROMETHEUS_TASK_QUEUE=prometheus_tasks
PROMETHEUS_LOG_STREAM=prometheus_logs
PROMETHEUS_NOTIFICATION_CHANNEL=prometheus_notifications
PROMETHEUS_KILL_SWITCH_KEY=prometheus_kill_switch

# -----------------------------------------------------------------------------
# Redis
# Docker Compose uses host "redis" inside containers.
# Local host runs may use 127.0.0.1.
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Lean model routing
# Lean mode talks directly to an OpenAI-compatible API and does not require
# LiteLLM unless you enable the router profile.
# -----------------------------------------------------------------------------
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
PROMETHEUS_CONSULTANT_MODEL=gpt-4o-mini
PROMETHEUS_CHEAP_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Optional LiteLLM provider keys
# Used only when running docker-compose.core.yml or the lean router profile.
# Keep real keys only in your local .env or server secret manager.
# -----------------------------------------------------------------------------
REAL_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Telegram integration
# TELEGRAM_CHAT_ID is also used as the authorized owner ID by telegram_gateway.py.
# Only needed when running the telegram profile.
# -----------------------------------------------------------------------------
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
VPS_PUBLIC_IP=127.0.0.1

# -----------------------------------------------------------------------------
# Dashboard/browser API targets
# For local Docker, these defaults are correct.
# On a VPS, replace localhost with your server IP/domain.
# -----------------------------------------------------------------------------
VITE_API_BASE=http://localhost:8000
VITE_WS_BASE=ws://localhost:8000

# -----------------------------------------------------------------------------
# Service ports
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
DASHBOARD_PORT=5173
LITELLM_PORT=4000
CHROMA_PORT=8001
