# Agent Prometheus environment example
# Copy this file to .env and fill in real secrets locally.
# Never commit .env.

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
PROMETHEUS_WORKSPACE=workspace
PROMETHEUS_AUTO_APPLY=false
PROMETHEUS_MAX_FILES=120
PROMETHEUS_MAX_FILE_CHARS=6000
PROMETHEUS_EVIDENCE_BUDGET=28000
PROMETHEUS_TASK_QUEUE=prometheus_tasks
PROMETHEUS_LOG_STREAM=prometheus_logs
PROMETHEUS_NOTIFICATION_CHANNEL=prometheus_notifications
PROMETHEUS_KILL_SWITCH_KEY=prometheus_kill_switch

# -----------------------------------------------------------------------------
# Redis
# Docker Compose usually uses host "redis" inside containers.
# Local host runs may use 127.0.0.1.
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Model routing
# Prometheus talks to an OpenAI-compatible endpoint.
# Recommended: point this at LiteLLM, then let LiteLLM route to Groq/OpenAI/etc.
# -----------------------------------------------------------------------------
OPENAI_API_BASE=http://litellm:4000/v1
OPENAI_API_KEY=sk-local-litellm-key
PROMETHEUS_CONSULTANT_MODEL=consultant-model
PROMETHEUS_CHEAP_MODEL=utility-model
PROMETHEUS_REVIEW_MODEL=review-model

# -----------------------------------------------------------------------------
# Groq through LiteLLM
# Keep the real key in your local .env or secret manager.
# -----------------------------------------------------------------------------
GROQ_API_KEY=
PROMETHEUS_CONSULTANT_PROVIDER_MODEL=groq/llama-3.1-70b-versatile
PROMETHEUS_UTILITY_PROVIDER_MODEL=groq/llama-3.1-8b-instant
PROMETHEUS_REVIEW_PROVIDER_MODEL=groq/llama-3.1-70b-versatile

# -----------------------------------------------------------------------------
# Optional provider keys
# -----------------------------------------------------------------------------
OPENAI_PROVIDER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Telegram integration
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# -----------------------------------------------------------------------------
# GitHub integration / upstream watcher
# GitHub Actions supplies GITHUB_TOKEN automatically for workflows.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Service ports
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
DASHBOARD_PORT=3000
LITELLM_PORT=4000
CHROMA_PORT=8001
